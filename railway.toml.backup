[build]
  builder = "NIXPACKS"
  buildCommand = "pip install -r backend/requirements.txt"
  startCommand = "python -c \"import uvicorn; uvicorn.run('backend.app:app', host='0.0.0.0', port=int(os.environ.get('PORT', 8000)))\""

[deploy]
  restartPolicy = "on_failure"
  healthcheckPath = "/health"
  healthcheckTimeout = 60